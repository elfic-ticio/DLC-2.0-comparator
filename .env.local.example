# Upstash Redis — these are set automatically by the Vercel KV / Upstash integration.
# Download the .env.local from: Vercel Dashboard → your project → Storage → .env.local
KV_REST_API_URL=your_kv_rest_api_url_here
KV_REST_API_TOKEN=your_kv_rest_api_token_here
KV_REST_API_READ_ONLY_TOKEN=your_kv_rest_api_read_only_token_here
