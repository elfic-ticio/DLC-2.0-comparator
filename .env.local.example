# Upstash Redis (Vercel KV successor)
# These are auto-set when you add the Upstash Redis integration from Vercel Marketplace
# For local dev: copy from your Vercel project → Integrations → Upstash → .env.local
UPSTASH_REDIS_REST_URL=your_upstash_rest_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token_here
